{
  "name": "m365_list_document_libraries",
  "domain": "files",
  "description": "List document libraries for a SharePoint site.",
  "kind": "hostless",
  "args": {
    "site_id": {
      "type": "string",
      "required": false
    },
    "site_name": {
      "type": "string",
      "required": false
    },
    "site_url": {
      "type": "string",
      "required": false
    },
    "hostname": {
      "type": "string",
      "required": false
    },
    "site_path": {
      "type": "string",
      "required": false
    },
    "library_name": {
      "type": "string",
      "required": false
    },
    "query": {
      "type": "string",
      "required": false
    },
    "limit": {
      "type": "integer",
      "required": false
    },
    "force_refresh": {
      "type": "boolean",
      "required": false
    }
  },
  "returns": {
    "type": "object"
  },
  "requires": {
    "auth": true,
    "scopes": [
      "Sites.Read.All",
      "Files.Read.All"
    ]
  },
  "execution": {
    "strategy": "direct_api",
    "tool": "m365_list_document_libraries"
  },
  "verify": {
    "strategy": "none"
  },
  "risk": "read"
}
