{
  "name": "m365_update_drive_item",
  "domain": "files",
  "description": "Rename and/or move a SharePoint or OneDrive file or folder within the same drive.",
  "kind": "hostless",
  "args": {
    "site_id": { "type": "string", "required": false },
    "site_name": { "type": "string", "required": false },
    "site_url": { "type": "string", "required": false },
    "hostname": { "type": "string", "required": false },
    "site_path": { "type": "string", "required": false },
    "drive_id": { "type": "string", "required": false },
    "library_name": { "type": "string", "required": false },
    "item_id": { "type": "string", "required": false },
    "item_path": { "type": "string", "required": false },
    "new_name": { "type": "string", "required": false },
    "target_parent_item_id": { "type": "string", "required": false },
    "target_parent_path": { "type": "string", "required": false },
    "force_refresh": { "type": "boolean", "required": false }
  },
  "returns": { "type": "object" },
  "requires": {
    "auth": true,
    "scopes": ["Files.ReadWrite.All or Sites.ReadWrite.All"]
  },
  "execution": {
    "strategy": "direct_api",
    "tool": "m365_update_drive_item"
  },
  "verify": {
    "strategy": "followup_method",
    "method": "m365_get_drive_item"
  },
  "risk": "write"
}
