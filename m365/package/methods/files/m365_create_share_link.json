{
  "name": "m365_create_share_link",
  "domain": "files",
  "description": "Create a sharing link for a Microsoft 365 file.",
  "kind": "hostless",
  "args": {
    "site_id": {
      "type": "string",
      "required": false
    },
    "site_name": {
      "type": "string",
      "required": false
    },
    "site_url": {
      "type": "string",
      "required": false
    },
    "hostname": {
      "type": "string",
      "required": false
    },
    "site_path": {
      "type": "string",
      "required": false
    },
    "drive_id": {
      "type": "string",
      "required": false
    },
    "library_name": {
      "type": "string",
      "required": false
    },
    "item_id": {
      "type": "string",
      "required": false
    },
    "item_path": {
      "type": "string",
      "required": false
    },
    "link_type": {
      "type": "string",
      "required": false,
      "default": "view",
      "enum": [
        "view",
        "edit",
        "embed"
      ]
    },
    "scope": {
      "type": "string",
      "required": false,
      "default": "organization",
      "enum": [
        "organization",
        "anonymous",
        "users"
      ]
    },
    "retain_inherited_permissions": {
      "type": "boolean",
      "required": false
    },
    "expiration_datetime": {
      "type": "string",
      "required": false
    },
    "force_refresh": {
      "type": "boolean",
      "required": false
    }
  },
  "returns": {
    "type": "object"
  },
  "requires": {
    "auth": true,
    "scopes": [
      "Files.ReadWrite.All or Files.ReadWrite"
    ]
  },
  "execution": {
    "strategy": "direct_api",
    "tool": "m365_create_share_link"
  },
  "verify": {
    "strategy": "none"
  },
  "risk": "write"
}
