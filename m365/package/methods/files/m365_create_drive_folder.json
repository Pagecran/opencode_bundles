{
  "name": "m365_create_drive_folder",
  "domain": "files",
  "description": "Create a folder in a SharePoint or OneDrive document library.",
  "kind": "hostless",
  "args": {
    "site_id": { "type": "string", "required": false },
    "site_name": { "type": "string", "required": false },
    "site_url": { "type": "string", "required": false },
    "hostname": { "type": "string", "required": false },
    "site_path": { "type": "string", "required": false },
    "drive_id": { "type": "string", "required": false },
    "library_name": { "type": "string", "required": false },
    "parent_item_id": { "type": "string", "required": false },
    "parent_path": { "type": "string", "required": false },
    "folder_name": { "type": "string", "required": true },
    "conflict_behavior": {
      "type": "string",
      "required": false,
      "default": "rename",
      "enum": ["rename", "replace", "fail"]
    },
    "force_refresh": { "type": "boolean", "required": false }
  },
  "returns": { "type": "object" },
  "requires": {
    "auth": true,
    "scopes": ["Files.ReadWrite.All or Sites.ReadWrite.All"]
  },
  "execution": {
    "strategy": "direct_api",
    "tool": "m365_create_drive_folder"
  },
  "verify": {
    "strategy": "followup_method",
    "method": "m365_list_drive_items"
  },
  "risk": "write"
}
