{
  "name": "m365_download_drive_item",
  "domain": "files",
  "description": "Download a small SharePoint or OneDrive file and return base64 content.",
  "kind": "hostless",
  "args": {
    "site_id": { "type": "string", "required": false },
    "site_name": { "type": "string", "required": false },
    "site_url": { "type": "string", "required": false },
    "hostname": { "type": "string", "required": false },
    "site_path": { "type": "string", "required": false },
    "drive_id": { "type": "string", "required": false },
    "library_name": { "type": "string", "required": false },
    "item_id": { "type": "string", "required": false },
    "item_path": { "type": "string", "required": false },
    "max_bytes": { "type": "integer", "required": false, "default": 5242880 },
    "force_refresh": { "type": "boolean", "required": false }
  },
  "returns": { "type": "object" },
  "requires": {
    "auth": true,
    "scopes": ["Files.Read.All"]
  },
  "execution": {
    "strategy": "direct_api",
    "tool": "m365_download_drive_item"
  },
  "verify": { "strategy": "none" },
  "risk": "read"
}
