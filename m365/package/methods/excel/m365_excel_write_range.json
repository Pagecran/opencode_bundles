{
  "name": "m365_excel_write_range",
  "domain": "excel",
  "description": "Write values or formulas into an Excel worksheet range.",
  "kind": "hostless",
  "args": {
    "site_id": {
      "type": "string",
      "required": false
    },
    "site_name": {
      "type": "string",
      "required": false
    },
    "site_url": {
      "type": "string",
      "required": false
    },
    "hostname": {
      "type": "string",
      "required": false
    },
    "site_path": {
      "type": "string",
      "required": false
    },
    "drive_id": {
      "type": "string",
      "required": false
    },
    "library_name": {
      "type": "string",
      "required": false
    },
    "item_id": {
      "type": "string",
      "required": false
    },
    "item_path": {
      "type": "string",
      "required": false
    },
    "worksheet_id": {
      "type": "string",
      "required": false
    },
    "worksheet_name": {
      "type": "string",
      "required": false
    },
    "range_address": {
      "type": "string",
      "required": true
    },
    "values": {
      "type": "any",
      "required": true
    },
    "formulas": {
      "type": "any",
      "required": false
    },
    "formulas_local": {
      "type": "any",
      "required": false
    },
    "number_format": {
      "type": "any",
      "required": false
    },
    "force_refresh": {
      "type": "boolean",
      "required": false
    }
  },
  "returns": {
    "type": "object"
  },
  "requires": {
    "auth": true,
    "scopes": [
      "Files.ReadWrite.All or Files.ReadWrite"
    ]
  },
  "execution": {
    "strategy": "direct_api",
    "tool": "m365_excel_write_range"
  },
  "verify": {
    "strategy": "readback",
    "method": "m365_excel_read_range"
  },
  "risk": "write"
}
