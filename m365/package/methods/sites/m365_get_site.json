{
  "name": "m365_get_site",
  "domain": "sites",
  "description": "Resolve a SharePoint site by id, name, URL, or hostname/path.",
  "kind": "hostless",
  "args": {
    "site_id": {
      "type": "string",
      "required": false
    },
    "site_name": {
      "type": "string",
      "required": false
    },
    "site_url": {
      "type": "string",
      "required": false
    },
    "hostname": {
      "type": "string",
      "required": false
    },
    "site_path": {
      "type": "string",
      "required": false
    },
    "force_refresh": {
      "type": "boolean",
      "required": false
    }
  },
  "returns": {
    "type": "object"
  },
  "requires": {
    "auth": true,
    "scopes": [
      "Sites.Read.All"
    ]
  },
  "execution": {
    "strategy": "direct_api",
    "tool": "m365_get_site"
  },
  "verify": {
    "strategy": "none"
  },
  "risk": "read"
}
