{
  "name": "m365_powerpoint_inspect_media_batch",
  "domain": "powerpoint",
  "description": "Inspect embedded and linked media across multiple PowerPoint files stored in Microsoft 365.",
  "kind": "hostless",
  "args": {
    "site_id": { "type": "string", "required": false },
    "site_name": { "type": "string", "required": false },
    "site_url": { "type": "string", "required": false },
    "hostname": { "type": "string", "required": false },
    "site_path": { "type": "string", "required": false },
    "drive_id": { "type": "string", "required": false },
    "library_name": { "type": "string", "required": false },
    "items": {
      "type": "array",
      "required": true,
      "description": "Array of PowerPoint file references. Each item can provide item_id or item_path and may override shared site or drive fields."
    },
    "include_template_parts": { "type": "boolean", "required": false, "default": true },
    "include_external_media": { "type": "boolean", "required": false, "default": true },
    "max_bytes": { "type": "integer", "required": false, "default": 52428800 },
    "limit": { "type": "integer", "required": false, "default": 10 },
    "force_refresh": { "type": "boolean", "required": false }
  },
  "returns": { "type": "object" },
  "requires": {
    "auth": true,
    "scopes": ["Files.Read.All"]
  },
  "execution": {
    "strategy": "direct_api",
    "tool": "m365_powerpoint_inspect_media_batch"
  },
  "verify": { "strategy": "none" },
  "risk": "read"
}
