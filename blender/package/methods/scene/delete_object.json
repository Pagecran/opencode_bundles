{
  "name": "delete_object",
  "domain": "scene",
  "description": "Delete one object by exact Blender name.",
  "kind": "host-backed",
  "risk": "destructive",
  "args": {
    "name": {
      "type": "string",
      "required": true,
      "description": "Exact Blender object name to remove."
    }
  },
  "returns": {
    "type": "object",
    "description": "Deletion result containing the removed object name and type."
  },
  "execution": {
    "strategy": "host_function",
    "package": "opencode_blender_bundle",
    "module": "handlers_scene",
    "function": "delete_object"
  },
  "requires": {
    "bridgeMethods": [
      "execute_code"
    ]
  },
  "verify": {
    "strategy": "followup_method",
    "method": "get_scene_info"
  }
}
