{
  "name": "open_level_sequence",
  "domain": "sequencer",
  "description": "Open a Level Sequence asset in the Sequencer editor.",
  "kind": "host-backed",
  "risk": "write",
  "args": {
    "sequence_path": {
      "type": "string",
      "required": true,
      "description": "Level Sequence asset path."
    }
  },
  "returns": {
    "type": "object",
    "description": "Sequence summary for the asset that was opened in Sequencer."
  },
  "execution": {
    "strategy": "host_script",
    "script": "unreal/editor/open_level_sequence.py"
  },
  "requires": {
    "bridgeMethods": [
      "execute_python"
    ]
  },
  "verify": {
    "strategy": "followup_method",
    "method": "get_sequence_info"
  }
}
