{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "plugins/**/*.ts",
    "runtime/**/*.ts",
    "_runtime/**/*.ts"
  ]
}
